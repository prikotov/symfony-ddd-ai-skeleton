#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * Bootstrap script — rename skeleton namespace and package metadata for a new project.
 *
 * Usage:
 *   php bin/bootstrap "MyVendor\MyProject" my-vendor/my-project "My project description"
 *
 * This will:
 *   - Replace namespace Skeleton\Common → MyVendor\MyProject (and Web, Console accordingly)
 *   - Replace package name prikotov/symfony-ddd-ai-skeleton → my-vendor/my-project
 *   - Replace description in composer.json
 *   - Update .env APP_SECRET with a random value
 *   - Remove itself (bin/bootstrap) after completion
 */

use Composer\Console\Application as ComposerApplication;
use Symfony\Component\Console\Input\StringInput;

function main(array $argv): int
{
    if (\count($argv) < 3) {
        echo "Usage: php bin/bootstrap <Namespace\\\\Prefix> <vendor/project> [description]\n";
        echo "Example: php bin/bootstrap \"Acme\\Shop\" acme/shop \"ACME Shop\"\n";
        return 1;
    }

    $namespace = $argv[1];
    $packageName = $argv[2];
    $description = $argv[3] ?? '';
    $rootDir = \dirname(__DIR__);

    $oldNamespaces = [
        'Skeleton\\Common' => $namespace,
        'Skeleton\\Web' => $namespace . '\\Web',
        'Skeleton\\Console' => $namespace . '\\Console',
    ];

    $oldPackage = 'prikotov/symfony-ddd-ai-skeleton';

    echo "Bootstrapping project...\n";
    echo "  Namespace: {$namespace}\n";
    echo "  Package:   {$packageName}\n";
    if ($description !== '') {
        echo "  Description: {$description}\n";
    }
    echo "\n";

    // Collect files to process
    $extensions = ['php', 'yaml', 'yml', 'twig', 'xml', 'dist', 'env', 'env.test'];
    $files = collectFiles($rootDir, $extensions);

    $replacements = 0;

    foreach ($files as $file) {
        $content = \file_get_contents($file);
        if ($content === false) {
            continue;
        }

        $newContent = $content;

        // Replace namespaces (longest first to avoid partial matches)
        \uasort($oldNamespaces, static fn (string $a, string $b): int => \strlen($b) - \strlen($a));

        foreach ($oldNamespaces as $old => $new) {
            $newContent = \str_replace($old, $new, $newContent);
        }

        // Replace package name
        $newContent = \str_replace($oldPackage, $packageName, $newContent);

        // Replace description in composer.json
        if ($description !== '' && \str_ends_with($file, 'composer.json')) {
          $newContent = (string)\preg_replace(
              '/"description":\s*"[^"]*"/',
              '"description": "' . \addslashes($description) . '"',
              $newContent,
          );
        }

        if ($newContent !== $content) {
            \file_put_contents($file, $newContent);
            $replacements++;
            echo "  Updated: " . \realpath($file) . "\n";
        }
    }

    // Generate a random APP_SECRET
    $envFile = $rootDir . '/.env';
    if (\is_file($envFile)) {
        $envContent = \file_get_contents($envFile);
        $secret = \bin2hex(\random_bytes(32));
        $envContent = (string)\preg_replace(
            '/APP_SECRET=.*/',
            'APP_SECRET=' . $secret,
            $envContent,
        );
        \file_put_contents($envFile, $envContent);
        echo "  Updated: APP_SECRET in .env\n";
    }

    echo "\nDone. {$replacements} files updated.\n";
    echo "\nNext steps:\n";
    echo "  1. Review the changes: git diff\n";
    echo "  2. Run: composer install\n";
    echo "  3. Run: make check\n";
    echo "  4. Remove this script: rm bin/bootstrap\n";

    return 0;
}

/**
 * @param string[] $extensions
 * @return string[]
 */
function collectFiles(string $dir, array $extensions): array
{
    $result = [];
    $skipDirs = ['vendor', 'var', '.git', 'node_modules', '.deptrac.cache'];

    $iterator = new RecursiveIteratorIterator(
        new RecursiveDirectoryIterator($dir, RecursiveDirectoryIterator::SKIP_DOTS),
    );

    foreach ($iterator as $file) {
        if (!$file->isFile()) {
            continue;
        }

        // Skip by directory
        $path = $file->getPathname();
        foreach ($skipDirs as $skip) {
            if (\str_contains($path, '/' . $skip . '/') || \str_contains($path, '\\' . $skip . '\\')) {
                continue 2;
            }
        }

        $ext = $file->getExtension();
        if (\in_array($ext, $extensions, true)) {
            $result[] = $path;
        }

        // Special: .env, .env.test files (no extension)
        $basename = $file->getBasename();
        if (\str_starts_with($basename, '.env')) {
            $result[] = $path;
        }
    }

    return \array_unique($result);
}

exit(main($argv));
