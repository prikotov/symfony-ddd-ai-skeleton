<div class="d-flex flex-wrap align-items-center justify-content-between mx-0 my-2 py-0 px-0 fs-9">
    <div class="d-flex">
        {% if this.total > 0 %}
        <nav aria-label="Page navigation">
            <ul class="pagination mb-0">
                <li class="page-item">
                    {% if this.page == 1 %}
                        <span class="page-link disabled">
                    <span class="fas fa-chevron-left"></span>
                </span>
                    {% else %}
                        <a class="page-link" href="{{ path(this.route, this.filter|merge({perPage: this.perPage, page: this.page - 1, sort: this.sort})) }}">
                            <span class="fas fa-chevron-left"></span>
                        </a>
                    {% endif %}
                </li>
                {% for item in this.pages %}
                    {% if this.page == item %}
                        <li class="page-item active" aria-current="page">
                            <span class="page-link">{{ item }}</span>
                        </li>
                    {% else %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path(this.route, this.filter|merge({perPage: this.perPage, page: item, sort: this.sort})) }}">{{ item }}</a>
                        </li>
                    {% endif %}
                {% endfor %}
                <li class="page-item">
                    {% if this.page == this.totalPage %}
                        <span class="page-link disabled">
                    <span class="fas fa-chevron-right"></span>
                </span>
                    {% else %}
                        <a class="page-link" href="{{ path(this.route, this.filter|merge({perPage: this.perPage, page: this.page + 1, sort: this.sort})) }}">
                            <span class="fas fa-chevron-right"></span>
                        </a>
                    {% endif %}
            </ul>
        </nav>
        {% endif %}
    </div>
    <div class="d-flex">
        {% if this.total == 0 %}
            Нет записей.
        {% else %}
            Показаны записи {{ this.firstItem }}-{{ this.lastItem }} из {{ this.total }}.
        {% endif %}
    </div>
</div>
